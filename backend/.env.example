# Project Infrastructure
PORT=5000
NODE_ENV=development
LOG_LEVEL=info
DATABASE_URL=

# Security Agent (Guardian)
SECURITY_API_KEY=your_security_api_key_here
SECURITY_MODEL=gpt-4o
GUARD_MODEL=gpt-4o-mini
GUARD_ENABLED=true

# Drafting Agent (Writer)
DRAFTING_API_KEY=your_drafting_api_key_here
DRAFTING_MODEL=sonar
DRAFTING_URL=https://api.perplexity.ai/chat/completions

# Validation Agent (Auditor)
VALIDATION_API_KEY=your_validation_api_key_here
VALIDATION_MODEL=gemini-2.5-flash

# Observability (Helicone)
HELICONE_ENABLED=false
HELICONE_API_KEY=sk-helicone-dummy
HELICONE_URL=http://localhost:8787/v1
